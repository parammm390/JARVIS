# FINNOR Public Environment Variables
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=
NEXT_PUBLIC_DEMO_MOCK_MODE=false

# FINNOR Secret Environment Variables (Server Only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-if-needed

# Optional lead email delivery
GMAIL_USER=your-gmail-address
GMAIL_APP_PASSWORD=your-gmail-app-password

# Personalized demo profile generation, server-side only
# If omitted, /api/generate-demo falls back to conservative mock extraction.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional Vapi server credential. Not required for browser calls.
VAPI_PRIVATE_KEY=
VAPI_WEBHOOK_SECRET=

# Optional notification when a demo is generated
LEAD_NOTIFY_WEBHOOK_URL=

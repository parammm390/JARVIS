# ============ Finnor OS environment (§21) — every var explained ============

# Postgres connection string (Supabase project → Settings → Database, or local docker-compose)
DATABASE_URL=postgres://finnor:finnor@localhost:5432/finnor

# Supabase project URL + service role key (Auth verification only — data access goes
# through DATABASE_URL with RLS; the service key never bypasses tenant scoping in app code)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vapi (voice). PRIVATE api key from dashboard.vapi.ai (server-side calls)
VAPI_API_KEY=
# Shared secret Vapi sends in x-vapi-secret on webhooks (set the same value in Vapi dashboard)
VAPI_WEBHOOK_SECRET=
# Public key (client SDKs only, not used server-side yet)
VAPI_PUBLIC_KEY=
# The assistant that speaks confirmations/failures (create in Vapi dashboard)
VAPI_ASSISTANT_ID=
# The Vapi phone number id calls are placed FROM (Vapi dashboard -> Phone Numbers)
VAPI_PHONE_NUMBER_ID=PLACEHOLDER_NEEDS_REAL_VALUE
# Which tenant inbound Vapi calls belong to, until per-number tenant mapping exists
VAPI_DEFAULT_TENANT_ID=00000000-0000-4000-8000-000000000001

# GoHighLevel Private Integration Token (Settings → Private Integrations; scopes:
# contacts, calendar, conversations, opportunities only — least privilege, §28)
GOHIGHLEVEL_API_KEY=
GHL_LOCATION_ID=
# Calendar used for water test bookings
GHL_WATER_TEST_CALENDAR_ID=PLACEHOLDER_NEEDS_REAL_VALUE

# Groq (default LLM provider, console.groq.com). Model override optional.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Redis for short-term memory (§10)
REDIS_URL=redis://localhost:6379

# Dev-only: accept x-tenant-id headers instead of Supabase JWTs. NEVER set in production.
AUTH_DEV_BYPASS=0

# Console → API wiring
NEXT_PUBLIC_API_URL=http://localhost:3100
NEXT_PUBLIC_DEV_TENANT_ID=00000000-0000-4000-8000-000000000001

# Not yet needed this build — placeholders for future integrations (§21):
EXA_API_KEY=          # web search (competitor/review lookup plugin, when built)
QUICKBOOKS_API_KEY=PLACEHOLDER_NEEDS_REAL_VALUE
EMBEDDINGS_API_KEY=PLACEHOLDER_NEEDS_REAL_VALUE  # provider TBD — verify current pricing before choosing

# Comms drivers: auto = real GHL/Vapi when keys exist, sandbox otherwise (workflows
# complete for real either way; sandbox only simulates the carrier delivery hop)
COMMS_MODE=auto
# Browser voice (console /talk page) — Vapi PUBLIC key + assistant id
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=

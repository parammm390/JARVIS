# ============ Finnor OS environment (§21) — every var explained ============

# Secrets provider (packages/security/src/secrets.ts) — "env" (default: plain
# process.env, fine for local dev) or "aws-secrets-manager" (production). Loaded once
# per process via ensureSecretsLoaded(), re-checked every SECRET_REFRESH_MS.
SECRETS_PROVIDER=env
# JSON map { ENV_VAR_NAME: "secret-id-or-arn" } — only read when SECRETS_PROVIDER=aws-secrets-manager.
# Each secret can be a single string value or a JSON object containing ENV_VAR_NAME.
FINNOR_SECRET_IDS={}
# How often (ms) to re-pull from AWS Secrets Manager — this IS the rotation mechanism
# (periodic re-pull, not push-based). Default 300000 (5 min).
SECRET_REFRESH_MS=300000
# Safety valve, NOT a feature to enable: setting this to 1 with NODE_ENV=production
# makes ensureSecretsLoaded() throw at startup rather than silently run on plaintext
# env vars in prod. Leave at 0/unset everywhere.
ALLOW_PLAINTEXT_ENV_SECRETS=0

# Postgres connection string (Supabase project → Settings → Database, or local docker-compose)
DATABASE_URL=postgres://finnor:finnor@localhost:5432/finnor

# Supabase project URL + service role key (Auth verification only — data access goes
# through DATABASE_URL with RLS; the service key never bypasses tenant scoping in app code)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vapi (voice). PRIVATE api key from dashboard.vapi.ai (server-side calls)
VAPI_API_KEY=
# HMAC secret for the webhook's x-vapi-signature header (t=<unix>,v1=<hex hmac over
# `${t}.${rawBody}`>, +/-300s replay window). Fails OPEN only when unset AND
# NODE_ENV != production (dev convenience) — fails CLOSED otherwise. Set the same
# value in the Vapi dashboard.
VAPI_WEBHOOK_SECRET=
# Public key (client SDKs only, not used server-side yet)
VAPI_PUBLIC_KEY=
# The assistant that speaks confirmations/failures (create in Vapi dashboard)
VAPI_ASSISTANT_ID=
# The Vapi phone number id calls are placed FROM (Vapi dashboard -> Phone Numbers)
VAPI_PHONE_NUMBER_ID=PLACEHOLDER_NEEDS_REAL_VALUE
# Which tenant inbound Vapi calls belong to, until per-number tenant mapping exists
VAPI_DEFAULT_TENANT_ID=00000000-0000-4000-8000-000000000001

# GoHighLevel Private Integration Token (Settings → Private Integrations; scopes:
# contacts, calendar, conversations, opportunities only — least privilege, §28)
GOHIGHLEVEL_API_KEY=
GHL_LOCATION_ID=
# Calendar used for water test bookings
GHL_WATER_TEST_CALENDAR_ID=PLACEHOLDER_NEEDS_REAL_VALUE
# GHL signs marketplace webhooks RSA-SHA256 (header x-wh-signature) against GHL's own
# published public key — get this from the HighLevel developer dashboard, it is NOT a
# secret you generate. Unset = same as VAPI_WEBHOOK_SECRET's dev-convenience fallback.
GHL_WEBHOOK_PUBLIC_KEY=

# Groq (default LLM provider, console.groq.com). Model override optional.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Sentry (packages/tools/src/observability.ts) — error tracking + LLM/tool-call
# breadcrumbs (provider/tool name, latency, ok/fail — never prompt/response text or
# tool input/output). Sentry.init() no-ops harmlessly without this set.
SENTRY_DSN=

# Redis for short-term memory (§10)
REDIS_URL=redis://localhost:6379

# Dev-only: accept x-tenant-id headers instead of Supabase JWTs. Enforced in code too
# (apps/api/lib/auth.ts): this never applies when NODE_ENV=production, regardless of
# this value, so a misconfigured prod deploy that left it set to 1 stays safe.
AUTH_DEV_BYPASS=0

# Per-tenant fixed-window rate limit (apps/api/lib/rate-limit.ts), requests/minute.
RATE_LIMIT_PER_MINUTE=120

# Console → API wiring
NEXT_PUBLIC_API_URL=http://localhost:3100
NEXT_PUBLIC_DEV_TENANT_ID=00000000-0000-4000-8000-000000000001

# Not yet needed this build — placeholders for future integrations (§21):
EXA_API_KEY=          # web search (competitor/review lookup plugin, when built)
EMBEDDINGS_API_KEY=PLACEHOLDER_NEEDS_REAL_VALUE  # §5.1: Voyage AI voyage-3.5 (VoyageEmbedder) — sign up at voyage.ai, see docs/owner-actions.md. Unset/placeholder in production is a hard, loud failure (FailClosedEmbedder), never a silent fake — only NODE_ENV=test may use DeterministicLocalEmbedder.

# Ad performance (packages/tools/src/ads.ts) — set either block to go live automatically,
# leave both blank to keep demo data. No code change needed either way.
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=          # numeric, without the "act_" prefix
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_CUSTOMER_ID=

# QuickBooks Online (packages/tools/src/quickbooks.ts) — OAuth2, not a static API key
# (QUICKBOOKS_API_KEY from earlier drafts of this file was the wrong shape entirely;
# QBO has no such thing). Set all four to sync native invoices out automatically.
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REFRESH_TOKEN=
QUICKBOOKS_REALM_ID=
QUICKBOOKS_ENVIRONMENT=sandbox   # "sandbox" or "production"

# Stripe (packages/tools/src/stripe.ts) — payment-link creation via Checkout Sessions.
# Set PAYMENTS_BINDING=stripe once STRIPE_SECRET_KEY is set to actually use it (the
# capability contract stays emulator-only otherwise, same opt-in shape as every other
# *_BINDING switch below).
STRIPE_SECRET_KEY=
# HMAC secret for the webhook's stripe-signature header (same t=,v1= shape as Vapi's).
# Unset = generic emulator/dev body shape still accepted at /api/webhooks/payment.
STRIPE_WEBHOOK_SECRET=
# Base URL for the Checkout Session's success/cancel redirect (…/success, …/cancel appended)
PAYMENTS_RETURN_URL_BASE=https://finnorai.com/pay
PAYMENTS_BINDING=emulator   # "stripe" or "emulator" (default)

# DocuSign (packages/tools/src/docusign.ts) — JWT-grant (RS256) e-signature envelopes.
# Set ESIGN_BINDING=docusign once all four below are set to actually use it.
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_PRIVATE_KEY=          # PEM, keep the literal newlines or use \n-escaped form
DOCUSIGN_BASE_URL=https://demo.docusign.net   # demo by default; production is docusign.net
# HMAC secret for DocuSign Connect's x-docusign-signature-1 header (plain base64
# HMAC-SHA256 over the raw body, no timestamp — unlike Vapi/Stripe's t=,v1= shape).
DOCUSIGN_CONNECT_SECRET=
ESIGN_BINDING=emulator   # "docusign" or "emulator" (default)

# Comms drivers: auto = real GHL/Vapi when keys exist, sandbox otherwise (workflows
# complete for real either way; sandbox only simulates the carrier delivery hop)
COMMS_MODE=auto
# Browser voice (console /talk page) — Vapi PUBLIC key + assistant id
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=

# Comma-separated action_type allowlist routing to the new LangGraph-based executor
# (packages/orchestration/src/graph/*) instead of the legacy GatedExecutor. Empty by
# default — a per-action-type migration switch, not a process-wide flag. Requires
# `npm run setup:langgraph` to have been run once against DATABASE_URL first.
ORCHESTRATION_ENGINE_GRAPH_ACTION_TYPES=

{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "installCommand": "npm install"
  },
  "deploy": {
    "startCommand": "sh -c 'npx tsx apps/$SERVICE_APP/src/index.ts'",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
